##############################################################
# ERPNext School Management System — Environment Configuration
# VALIDATED Version: ERPNext v15.109.3 | Frappe v15.111.1
# Generated: 2026-06-16 | Research-validated as of June 2026
# IMPORTANT: Change ALL passwords, tokens, and secrets!
##############################################################

# ─────────────────────────────────────────────────────────────
# ERPNext / Frappe Versions (PINNED — research-validated)
# Source: https://github.com/frappe/erpnext/releases
# ─────────────────────────────────────────────────────────────
# The custom image tag you will build locally
CUSTOM_IMAGE=school-erpnext
CUSTOM_TAG=v15.109.3

# Used if you want to pull official image as base
ERPNEXT_VERSION=v15.109.3
FRAPPE_VERSION=version-15

# ─────────────────────────────────────────────────────────────
# Site Configuration
# ─────────────────────────────────────────────────────────────
SITE_NAME=school.localhost
# Change to your actual domain when using Cloudflare Tunnel
SITE_DOMAIN=erp.school.example.com
FRAPPE_SITE_NAME_HEADER=$$host

# ─────────────────────────────────────────────────────────────
# Administrator Credentials (CHANGE THESE BEFORE DEPLOYING!)
# ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=your_admin_password_here
# Generate encryption key: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate_your_own_fernet_key_here

# ─────────────────────────────────────────────────────────────
# MariaDB Configuration
# Version: 10.6.x — Required by ERPNext v15
# ─────────────────────────────────────────────────────────────
MARIADB_IMAGE=mariadb
MARIADB_TAG=10.6
DB_HOST=db
DB_PORT=3306
MARIADB_ROOT_PASSWORD=your_db_root_password_here
MARIADB_USER=frappe
MARIADB_PASSWORD=your_db_frappe_password_here
MARIADB_DATABASE=_frappe_main

# ─────────────────────────────────────────────────────────────
# Redis Configuration
# Version: 7.2.x — Stable Alpine build
# ─────────────────────────────────────────────────────────────
REDIS_IMAGE=redis
REDIS_TAG=7.2-alpine
REDIS_CACHE_URL=redis://redis-cache:6379
REDIS_QUEUE_URL=redis://redis-queue:6379
REDIS_SOCKETIO_URL=redis://redis-socketio:6379

# ─────────────────────────────────────────────────────────────
# Cloudflare Tunnel Configuration
# Get token: https://one.dash.cloudflare.com/
# → Zero Trust → Networks → Tunnels → Create Tunnel → Docker
# ─────────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# ─────────────────────────────────────────────────────────────
# Backup Configuration
# ─────────────────────────────────────────────────────────────
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION_KEY=generate_your_own_fernet_key_here

# S3-compatible backup (optional — set S3_BACKUP_ENABLED=true to activate)
S3_BACKUP_ENABLED=false
S3_BUCKET_NAME=school-erpnext-backups
S3_ACCESS_KEY=AKIACHANGEME
S3_SECRET_KEY=changeme-s3-secret
S3_ENDPOINT_URL=https://s3.amazonaws.com
S3_REGION=us-east-1

# ─────────────────────────────────────────────────────────────
# Email / SMTP Configuration
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=1
SMTP_USERNAME=school@example.com
SMTP_PASSWORD=change-me-smtp-password
DEFAULT_SENDER_EMAIL=noreply@school.example.com
DEFAULT_SENDER_NAME="School ERP System"

# ─────────────────────────────────────────────────────────────
# AI Features (Optional — change AI_ENABLED=true to activate)
# ─────────────────────────────────────────────────────────────
AI_ENABLED=false
OPENAI_API_KEY=sk-change-me-openai-key
OPENAI_MODEL=gpt-4o

# ─────────────────────────────────────────────────────────────
# Internal ports (NOT exposed to internet — Cloudflare Tunnel only)
# ─────────────────────────────────────────────────────────────
NGINX_PORT=8080
PROXY_TIMEOUT=120
CLIENT_MAX_BODY_SIZE=50m

# ─────────────────────────────────────────────────────────────
# Docker Configuration
# ─────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=erpnext-school
NETWORK_NAME=erpnext-school-network

# ─────────────────────────────────────────────────────────────
# School Configuration
# ─────────────────────────────────────────────────────────────
SCHOOL_NAME="My School"
SCHOOL_SHORT_NAME=MS
SCHOOL_ABBREVIATION=MS
DEFAULT_CURRENCY=INR
DEFAULT_COUNTRY=India
DEFAULT_LANGUAGE=en
DEFAULT_TIMEZONE=Asia/Kolkata
